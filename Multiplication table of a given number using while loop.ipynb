    "num=int(input(\"Enter the number:\"))\n",
    "i=1\n",
    "print(f\"Multiplication table for {num}:\")\n",
    "while i<=10:\n",
    "    print(f\"{num}x{i}={num*i}\")\n",
    "    i+=1"
